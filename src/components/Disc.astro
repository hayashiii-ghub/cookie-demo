---
// the tray leaf: the well, the true-size disc, and the marker's 15-mark burn.
// frame.js drives each mark's --w by class name; the class list here IS the timeline's
// cast list (MARKS in frame.js) — add a mark there and here, in the same breath.
---
      <!-- the tray: the right leaf. the disc is clipped to its hub and never moves. -->
      <div class="tray">
        <div class="well" aria-hidden="true"></div>
        <div class="disc cd1" id="cd1">
        <div class="hub" aria-hidden="true"></div>
        <!-- the wobble every mark is pushed through (filter:url(#wob) on .doodle span):
             fractal noise displacing the ink a few px, which is the difference between
             a vector and a hand. lives here so the ids ship beside their one consumer. -->
        <svg width="0" height="0" style="position:absolute" aria-hidden="true"><filter id="wob" x="-20%" y="-20%" width="140%" height="140%"><feTurbulence type="fractalNoise" baseFrequency="0.028" numOctaves="2" seed="7"/><feDisplacementMap in="SourceGraphic" scale="3" xChannelSelector="R" yChannelSelector="G"/></filter></svg>
        <div class="doodle" id="doodle">
          <span class="d-njk">뉴진스</span>
          <!-- NEWJEANS rides the disc's own top curve, as in the MV. the arc is inline-styled
               stroke:none so the generic .doodle path rule cannot ink it. -->
          <span class="d-nj"><svg viewBox="0 0 350 96"><path id="nj-arc" style="stroke:none" fill="none" d="M10 76 Q175 28 340 64"/><text text-anchor="middle"><textPath href="#nj-arc" startOffset="50%">NEWJEANS</textPath></text></svg></span>
          <!-- what the MV's own prop disc says: the four singles, each in its own pen —
               ATTENTION underlined, HYPE BOY boxed in blue, HURT across the big star,
               CÖOKIE crowned in orange. the cut box is the archivist's one addition;
               the spec vocabulary (type/color/layout) stays in the booklet. -->
          <span class="d-att">ATTENTION</span>
          <span class="d-hype">HYPE<br />BOY</span>
          <span class="d-song"><svg class="crown" viewBox="0 0 32 18"><path pathLength="1" d="M3 16 L5 5 L11 11 L16 3 L21 11 L27 5 L29 16"/></svg>CÖOKIE</span>
          <span class="d-cut">2:13-2:20</span>
          <span class="d-hurt"><svg viewBox="0 0 32 32"><path pathLength="1" d="M16 3 L19.7 12 L29 12.7 L21.5 18.8 L24.2 28 L16 22.4 L7.8 28 L10.5 18.8 L3 12.7 L12.3 12 Z"/><path pathLength="1" class="inner" d="M16 6.4 L18.9 13.5 L26.2 14 L20.3 18.8 L22.4 25.9 L16 21.5 L9.6 25.9 L11.7 18.8 L5.8 14 L13.1 13.5 Z"/></svg><i>HURT</i></span>
          <span class="d-smile"><svg viewBox="0 0 40 40"><circle pathLength="1" class="face" cx="20" cy="20" r="15.5"/><circle pathLength="1" class="dot" cx="14.6" cy="17.2" r="2.2"/><circle pathLength="1" class="dot" cx="25.4" cy="17.2" r="2.2"/><path pathLength="1" class="mouth" d="M12.5 24 q7.5 8 15 0"/></svg></span>
          <!-- the MV's arrows are all BLOCK arrows, outlines around a body: the grey one hands
               you to HYPE BOY, the blue drops onto CÖOKIE, the rose one is a flourish. -->
          <span class="d-arrow1"><svg viewBox="0 0 26 29"><path pathLength="1" d="M8 3 L18 3 L18 14 L24 14 L13 26 L2 14 L8 14 Z"/></svg></span>
          <span class="d-arrow2"><svg viewBox="0 0 52 32"><path pathLength="1" d="M4 26 C14 14 26 10 38 12 L36 5 L49 14 L37 22 L38 16 C27 14 17 17 8 27 Z"/></svg></span>
          <span class="d-arrow3"><svg viewBox="0 0 52 32"><path pathLength="1" d="M48 26 C38 14 26 10 14 12 L16 5 L3 14 L15 22 L14 16 C25 14 35 17 44 27 Z"/></svg></span>
          <span class="d-flow"><svg viewBox="0 0 36 36"><ellipse pathLength="1" cx="18" cy="8.5" rx="4.4" ry="7.4"/><ellipse pathLength="1" cx="18" cy="8.5" rx="4.4" ry="7.4" transform="rotate(72 18 18)"/><ellipse pathLength="1" cx="18" cy="8.5" rx="4.4" ry="7.4" transform="rotate(144 18 18)"/><ellipse pathLength="1" cx="18" cy="8.5" rx="4.4" ry="7.4" transform="rotate(216 18 18)"/><ellipse pathLength="1" cx="18" cy="8.5" rx="4.4" ry="7.4" transform="rotate(288 18 18)"/><circle pathLength="1" class="fillc" cx="18" cy="18" r="3.6"/><ellipse pathLength="1" class="leaf" cx="31.5" cy="28" rx="4.2" ry="2.1" transform="rotate(38 31.5 28)"/><ellipse pathLength="1" class="leaf" cx="4.5" cy="28" rx="4.2" ry="2.1" transform="rotate(-38 4.5 28)"/></svg></span>
          <!-- the pink four-point sparkle from the close-up's right edge, and the heart
               scribbled onto the HURT star's shoulder -->
          <span class="d-star3"><svg viewBox="0 0 32 32"><path pathLength="1" d="M16 2 C17.6 10 21.5 14 30 16 C21.5 18 17.6 22 16 30 C14.4 22 10.5 18 2 16 C10.5 14 14.4 10 16 2 Z"/></svg></span>
          <span class="d-heart2"><svg viewBox="0 0 28 26"><path pathLength="1" d="M14 23 C14 23 3 15 3 9 C3 5.5 5.5 3 9 3 C11.5 3 13.2 4.4 14 6 C14.8 4.4 16.5 3 19 3 C22.5 3 25 5.5 25 9 C25 15 14 23 14 23 Z"/></svg></span>
          <!-- the gem from the MV's top-left corner: gold outline, red scribble inside -->
          <span class="d-gem"><svg viewBox="0 0 40 40"><path pathLength="1" class="gem" d="M20 3 C22 13 27 18 37 20 C27 22 22 27 20 37 C18 27 13 22 3 20 C13 18 18 13 20 3 Z"/><path pathLength="1" class="scr" d="M13 18.5 q3 -4 6 0 t6 0"/><path pathLength="1" class="scr" d="M15 24 q3.5 -3 7 0"/></svg></span>
        </div>
      </div>
      </div>
