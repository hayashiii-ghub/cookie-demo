      <button class="playbtn" id="play" type="button" aria-label="재생" aria-pressed="false"><svg viewBox="0 0 24 24"><path d="M7 5 L19 12 L7 19 Z"/></svg></button>
      <div class="tc"><span id="tc">2:13:00</span><small>2:13 → 2:20</small></div>
      <div class="track-bar" id="bar">
        <div class="rail"></div><div class="fill" id="fill"></div>
        <div class="cut" style="left:16%"></div><div class="marks" id="marks"></div><div class="head" id="head"></div>
      </div>
    </div>

    <div class="flash" id="flash"></div>
  </div>
</div>
</main>

<div class="track" id="track" aria-hidden="true"></div>

<script is:inline>
(function(){
  var $=function(id){return document.getElementById(id);};
  var bgDark=$('bgDark'),bgBlue=$('bgBlue'),bug=$('bug'),flash=$('flash'),
      tcEl=$('tc'),fill=$('fill'),head=$('head'),shotEl=$('shot'),hint=$('hint'),
      bar=$('bar'),marks=$('marks');
  var E={cd1:$('cd1'),doodle:$('doodle'),kase:$('case'),lid:$('lid'),cover:$('cover')};
  /* half a panel: shut, the case is centred on the stage; open, the 1300px spread is. */
  var PAN=325;
  var reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* the whole reel is authored on a fixed 1200x900 (4:3) stage and scaled to fit */
  var BW=1200, BH=900;
  function fitStage(){ var f=Math.min(innerWidth/BW, innerHeight/BH);
    var d=document.documentElement.style; d.setProperty('--fit', f);
    d.setProperty('--scan', f>=0.62?0.16:0);   /* kill scanlines when scaled small (moiré) */
    return f; }

  var mh='';for(var s=0;s<=7;s++){mh+='<b style="left:'+(s/7*100)+'%">2:'+(13+s)+'</b>';}marks.innerHTML=mh;

  function clamp(v,a,b){return v<a?a:v>b?b:v;}
  function seg(p,a,b){return clamp((p-a)/(b-a),0,1);}
  function lerp(a,b,t){return a+(b-a)*t;}
  function eOut(t){return 1-Math.pow(1-t,3);}
  function pad(n){return(n<10?'0':'')+n;}
  function fmt(p){var f=133*24+Math.round(p*168),sec=Math.floor(f/24),ff=f%24;return Math.floor(sec/60)+':'+pad(sec%60)+':'+pad(ff);}

  /* ===== cookie zoom + burst engine (canvas, drawn in 1200x900 stage coords) ===== */
  var cv=$('cookie'), ctx=cv.getContext('2d'), DPR=Math.min(2,window.devicePixelRatio||1);
  function sizeCookie(){ var f=fitStage();
    cv.width=Math.round(BW*f*DPR); cv.height=Math.round(BH*f*DPR);
    cv.style.width=BW+'px'; cv.style.height=BH+'px'; ctx.setTransform(f*DPR,0,0,f*DPR,0,0); }
  sizeCookie(); window.addEventListener('resize',sizeCookie);
  var MM=['#3ea04b','#2f7fd6','#e23b2f','#f2c53d','#e77f2a','#7b3fa0'];
  var TOP=[ {x:-0.48,y:-0.42,r:0.17,c:'#3ea04b',mm:1},{x:0.34,y:-0.5,r:0.18,c:'#5a2d1c',mm:0},
    {x:-0.56,y:0.48,r:0.16,c:'#2f7fd6',mm:1},{x:0.6,y:0.42,r:0.15,c:'#f2c53d',mm:1},
    {x:0.42,y:-0.05,r:0.10,c:'#e23b2f',mm:1},{x:0.66,y:-0.34,r:0.07,c:'#7b3fa0',mm:1},
    {x:0.04,y:0.12,r:0.11,c:'#4a2c17',mm:0},{x:-0.18,y:-0.08,r:0.08,c:'#4a2c17',mm:0},
    {x:-0.32,y:0.2,r:0.09,c:'#4a2c17',mm:0},{x:0.16,y:0.5,r:0.09,c:'#4a2c17',mm:0},{x:-0.04,y:-0.5,r:0.08,c:'#4a2c17',mm:0} ];

  /* the crust wobble, one law, shared by the canvas cookie, the disc doodle and the jacket art */
  function crustPath(g,cx,cy,R,N){ g.beginPath();
    for(var i=0;i<=N;i++){ var a=i/N*6.283, rad=R*(0.96+0.04*Math.sin(a*5+1.2)+0.02*Math.sin(a*9));
      var x=cx+Math.cos(a)*rad, y=cy+Math.sin(a)*rad; i?g.lineTo(x,y):g.moveTo(x,y); }
    g.closePath(); }

  /* a chocolate chunk is a broken solid: a body, a facet where the break caught the light,
     and one small specular on the facet's edge. a flat polygon with a soft blob on it is
     the plastic look — the facet is what makes it read as broken chocolate. */
  function chunk(g,x,y,r,rot,jag){ var i,pts=[];
    for(i=0;i<jag.length;i++){ var a=rot+i/jag.length*6.283;
      pts.push([x+Math.cos(a)*r*jag[i], y+Math.sin(a)*r*jag[i]]); }
    function poly(sh,dx,dy){ g.beginPath();
      for(i=0;i<pts.length;i++){ var px=x+(pts[i][0]-x)*sh+dx, py=y+(pts[i][1]-y)*sh+dy;
        i?g.lineTo(px,py):g.moveTo(px,py); } g.closePath(); }
    g.save();
    g.shadowColor='rgba(58,28,7,.5)'; g.shadowBlur=r*0.3; g.shadowOffsetY=r*0.1;
    poly(1,0,0);
    var cg=g.createLinearGradient(x-r*0.8,y-r*0.8,x+r*0.7,y+r*0.9);
    cg.addColorStop(0,'#6a4527');cg.addColorStop(0.42,'#3a2213');cg.addColorStop(1,'#1b0f08');
    g.fillStyle=cg; g.fill(); g.shadowColor='transparent';
    poly(0.6,-r*0.17,-r*0.19);
    g.fillStyle='rgba(150,102,60,.28)'; g.fill();
    g.beginPath(); g.ellipse(x-r*0.33,y-r*0.37,r*0.19,r*0.1,-0.7,0,6.283);
    g.fillStyle='rgba(255,238,212,.28)'; g.fill();
    g.restore(); }

  /* a candy shell is matte, not chrome. a broad soft light off the top-left, a thin dark rim
     where the shell turns away, and a specular small enough to stay a shell and not a marble. */
  function candy(g,x,y,r,c,tilt){ var ry=r*0.95; g.save();
    g.shadowColor='rgba(58,28,7,.45)'; g.shadowBlur=r*0.42; g.shadowOffsetY=r*0.15;
    g.beginPath(); g.ellipse(x,y,r,ry,tilt,0,6.283); g.fillStyle=c; g.fill();
    g.shadowColor='transparent';
    /* the light stays flat across the middle and only falls off in the last fifth of the
       radius. a gradient that brightens from the centre outward is what makes a marble. */
    var rg=g.createRadialGradient(x-r*0.22,y-ry*0.26,r*0.02,x,y,r*1.04);
    rg.addColorStop(0,'rgba(255,255,255,.17)');rg.addColorStop(0.44,'rgba(255,255,255,.04)');
    rg.addColorStop(0.8,'rgba(0,0,0,.02)');rg.addColorStop(0.94,'rgba(0,0,0,.13)');rg.addColorStop(1,'rgba(0,0,0,.26)');
    g.fillStyle=rg; g.beginPath(); g.ellipse(x,y,r,ry,tilt,0,6.283); g.fill();
    g.beginPath(); g.ellipse(x-r*0.33,y-ry*0.38,r*0.145,ry*0.085,-0.45,0,6.283);
    g.fillStyle='rgba(255,255,255,.34)'; g.fill(); g.restore(); }

  /* ===== the cookie is BAKED ONCE into an offscreen canvas, then blitted =====
     A flat radial gradient with circles on it reads as clip art at any size. What makes a
     cookie look baked is the stuff you cannot draw per frame: mottled dough, a few thousand
     specks of flour and toasted sugar, craquelure, and a rim that caught more heat than the
     middle. Bake it into one texture and the zoom becomes a macro shot instead of a scale-up.
     The crumbs are then literal crops of this same texture, so they are made of the cookie. */
  var TEX=1600, ctex=document.createElement('canvas'); ctex.width=ctex.height=TEX;
  (function(){ var tg=ctex.getContext('2d');
    var r=0.4242; function rnd(){ r=(r*9301+49297)%233280; return r/233280; }
    var C=TEX/2, R=C*0.98, i;

    tg.save(); crustPath(tg,C,C,R,180); tg.clip();
    var g=tg.createRadialGradient(C-R*0.26,C-R*0.3,R*0.06,C,C,R*1.02);
    g.addColorStop(0,'#f4d79f');g.addColorStop(0.42,'#e0b073');g.addColorStop(0.74,'#c78c48');g.addColorStop(1,'#a3652d');
    tg.fillStyle=g; tg.fillRect(0,0,TEX,TEX);

    /* mottling — dough never bakes evenly */
    for(i=0;i<240;i++){ var a=rnd()*6.283, d=Math.sqrt(rnd())*R,
        x=C+Math.cos(a)*d, y=C+Math.sin(a)*d, rr=R*(0.03+rnd()*0.13), dark=rnd()<0.5;
      var lg=tg.createRadialGradient(x,y,0,x,y,rr);
      lg.addColorStop(0, dark?'rgba(120,70,26,.11)':'rgba(255,232,186,.11)');
      lg.addColorStop(1, dark?'rgba(120,70,26,0)':'rgba(255,232,186,0)');
      tg.fillStyle=lg; tg.beginPath(); tg.arc(x,y,rr,0,6.283); tg.fill(); }

    /* flour, toasted sugar, and the odd over-baked fleck */
    for(i=0;i<5200;i++){ var a2=rnd()*6.283, d2=Math.sqrt(rnd())*R*0.99,
        sx=C+Math.cos(a2)*d2, sy=C+Math.sin(a2)*d2, big=rnd()<0.06,
        sr=R*(big?0.0035+rnd()*0.004:0.0008+rnd()*0.0026);
      tg.fillStyle = big ? 'rgba(92,52,18,.26)' : (rnd()<0.55 ? 'rgba(86,50,18,.2)' : 'rgba(255,243,214,.2)');
      tg.beginPath(); tg.arc(sx,sy,sr,0,6.283); tg.fill(); }

    /* craquelure: the pale lip goes down FIRST, then the split is cut into it. the other way
       round and the crack reads as a light thread lying on top of the cookie. both passes have
       to trace the SAME wobble, so the walk is resolved to points before anything is stroked. */
    tg.lineCap='round'; tg.lineJoin='round';
    for(i=0;i<6;i++){ var a3=rnd()*6.283, d3=rnd()*R*0.6, len=R*(0.2+rnd()*0.42),
        px=C+Math.cos(a3)*d3, py=C+Math.sin(a3)*d3, dir=rnd()*6.283, k;
      var lw=R*(0.004+rnd()*0.005), pts=[[px,py]];
      for(k=0;k<6;k++){ dir+=(rnd()-0.5)*1.15; px+=Math.cos(dir)*len/6; py+=Math.sin(dir)*len/6; pts.push([px,py]); }
      function walk(){ tg.beginPath(); tg.moveTo(pts[0][0],pts[0][1]);
        for(var j=1;j<pts.length;j++) tg.lineTo(pts[j][0],pts[j][1]); }
      tg.save(); tg.translate(0,-lw*0.75); walk();
      tg.lineWidth=lw*0.7; tg.strokeStyle='rgba(255,238,202,.2)'; tg.stroke(); tg.restore();
      walk(); tg.lineWidth=lw; tg.strokeStyle='rgba(84,44,12,.5)'; tg.stroke(); }

    /* the rim caught the heat */
    var eg=tg.createRadialGradient(C,C,R*0.66,C,C,R);
    eg.addColorStop(0,'rgba(120,66,22,0)');eg.addColorStop(0.7,'rgba(116,62,20,.2)');eg.addColorStop(1,'rgba(80,42,11,.74)');
    tg.fillStyle=eg; tg.fillRect(0,0,TEX,TEX);
    /* and the key light sits top-left, the same place it sits on the disc */
    var hg=tg.createRadialGradient(C-R*0.42,C-R*0.46,R*0.02,C-R*0.28,C-R*0.3,R*0.98);
    hg.addColorStop(0,'rgba(255,241,208,.30)');hg.addColorStop(1,'rgba(255,241,208,0)');
    tg.fillStyle=hg; tg.fillRect(0,0,TEX,TEX);
    tg.restore();

    crustPath(tg,C,C,R,180); tg.lineWidth=R*0.02; tg.strokeStyle='rgba(104,58,20,.45)'; tg.stroke();

    for(i=0;i<TOP.length;i++){ var t=TOP[i], tx=C+t.x*R, ty=C+t.y*R, tr=t.r*R;
      if(t.mm) candy(tg,tx,ty,tr,t.c,rnd()*0.7);
      else { var jag=[],n=7,j; for(j=0;j<n;j++) jag.push(0.78+rnd()*0.34);
        chunk(tg,tx,ty,tr,rnd()*6.283,jag); } }
  })();

  function bigCookie(cx,cy,R,alpha){ ctx.save(); ctx.globalAlpha=alpha;
    ctx.shadowColor='rgba(58,26,4,.5)'; ctx.shadowBlur=R*0.09; ctx.shadowOffsetY=R*0.045;
    ctx.drawImage(ctex, cx-R, cy-R, R*2, R*2); ctx.restore(); }

  /* a crumb is a torn piece of the same texture, not a small drawing of a cookie */
  function particle(x,y,s,rot,mm,col,alpha,q){ if(s<=0.3||alpha<=0)return;
    ctx.save(); ctx.globalAlpha=alpha; ctx.translate(x,y); ctx.rotate(rot);
    if(mm){ candy(ctx,0,0,s,col,0); }
    else { ctx.save(); ctx.beginPath();
      for(var i=0;i<q.wob.length;i++){ var a=i/q.wob.length*6.283, rr=s*q.wob[i];
        var px=Math.cos(a)*rr, py=Math.sin(a)*rr; i?ctx.lineTo(px,py):ctx.moveTo(px,py); }
      ctx.closePath(); ctx.save(); ctx.clip();
      ctx.drawImage(ctex, q.sx, q.sy, TEX*0.42, TEX*0.42, -s*1.2, -s*1.2, s*2.4, s*2.4);
      ctx.restore();
      ctx.lineWidth=s*0.1; ctx.strokeStyle='rgba(92,50,16,.5)'; ctx.stroke(); ctx.restore(); }
    ctx.restore(); }

  function crumbShape(rnd){ var w=[],i; for(i=0;i<9;i++) w.push(0.8+rnd()*0.34); return w; }
  var PART=[];
  (function(){ var r=0.1234; function rnd(){ r=(r*9301+49297)%233280; return r/233280; }
    for(var i=0;i<40;i++){ var mm=rnd()<0.3;
      PART.push({an:rnd()*6.283, sp:0.42+rnd()*0.95, sz:mm?14+rnd()*12:26+rnd()*26,
        rot:rnd()*6.283, spin:(rnd()*2-1)*3.2, gv:0.6+rnd()*0.8, mm:mm, col:mm?MM[(rnd()*MM.length)|0]:'#c88a44',
        wob:crumbShape(rnd), sx:TEX*(0.12+rnd()*0.46), sy:TEX*(0.12+rnd()*0.46)}); }
  })();
  /* the burst throws everything off-screen, but a handful of crumbs stay in frame, arc up,
     and drop onto the blue floor. they are what carries the cookie into the next shot —
     without them the CD would arrive in a room the cookie never entered. */
  var CRUMB=[];
  (function(){ var r=0.777; function rnd(){ r=(r*9301+49297)%233280; return r/233280; }
    for(var i=0;i<7;i++){ var mm=rnd()<0.45;
      CRUMB.push({dx:(rnd()*2-1)*270, up:230+rnd()*250, sz:mm?7+rnd()*4:9+rnd()*7,
        rot:rnd()*6.283, spin:(rnd()*2-1)*2.4, gv:0.85+rnd()*0.65, mm:mm,
        col:mm?MM[(rnd()*MM.length)|0]:'#c88a44', floor:0.74+rnd()*0.05,
        wob:crumbShape(rnd), sx:TEX*(0.12+rnd()*0.46), sy:TEX*(0.12+rnd()*0.46)}); }
  })();
  /* crumbs outlive the burst: thrown up, pulled down hard, and settled by 2:15. the floor band
     (0.74-0.79 of the stage) and the +-270px spread put every one of them on the shut lid, and
     the canvas sits above the stage, so they land ON it. they are brushed off as it lifts.
     they only have to prove the cookie was in this room; one still hanging in mid-air at 2:16
     proves the opposite. */
  function crumbs(p){ var t=seg(p,0.15,0.56); if(t<=0||t>=1) return;
    /* they must be gone by 0.355, when the lid has lifted far enough to expose the tray.
       a crumb that rode up on the lid cannot also still be lying on the disc. */
    var a=Math.min(seg(p,0.16,0.19),1-seg(p,0.29,0.355))*0.85;
    if(a<=0) return;
    var cx=BW/2, cy=BH*0.46;
    for(var i=0;i<CRUMB.length;i++){ var q=CRUMB[i];
      var x=cx+q.dx*t, y=cy-q.up*t + t*t*BH*2.2*q.gv;
      var fl=BH*q.floor, land=y>=fl; if(land) y=fl;
      particle(x,y,q.sz, q.rot+(reduce||land?0:t*q.spin), q.mm, q.col, a, q); } }

  function drawCookie(p){ var W=BW,H=BH; ctx.clearRect(0,0,W,H);
    if(p<0.05||p>0.56) return;
    var cx=W/2, cy=H*0.46, minD=Math.min(W,H), maxD=Math.max(W,H), maxR=maxD*0.8;
    if(p<0.15){ bigCookie(cx,cy, lerp(minD*0.05,maxR,eOut(seg(p,0.055,0.15))), 1); return; }
    if(p<=0.34){
      var b=seg(p,0.15,0.32);
      /* the cookie is rushing past the lens now. once it is bigger than the frame its chips
         are metre-wide polygons, and a sharp one reads as a grey mess rather than as speed.
         defocus it as it goes: what stays is a warm bloom, which is what a camera would see. */
      var fa=1-seg(p,0.15,0.19);
      if(fa>0){ ctx.save(); ctx.filter='blur('+((1-fa)*70+4).toFixed(1)+'px)';
        bigCookie(cx,cy, maxR*(1+0.25*b), fa*0.9); ctx.restore(); }
      /* gone by p=0.30. the canvas now draws over the stage, so a burst piece lingering at
         low alpha does not read as debris in the air, it reads as dirt on the lens. */
      var spread=Math.hypot(W,H)*0.72, grav=H*0.12, a=Math.min(seg(b,0,0.05),1-seg(b,0.45,0.88));
      for(var i=0;i<PART.length;i++){ var q=PART[i], d=eOut(b)*spread*q.sp;
        var x=cx+Math.cos(q.an)*d, y=cy+Math.sin(q.an)*d + b*b*grav*q.gv;
        particle(x,y,q.sz*(1-0.3*b), q.rot+(reduce?0:b*q.spin), q.mm, q.col, a, q); }
    }
    crumbs(p); }

  var maxScroll=1,lastP=0;
  function measure(){maxScroll=Math.max(1,document.documentElement.scrollHeight-window.innerHeight);}
  measure();window.addEventListener('resize',measure);

  /* ===== the burn, in the order a hand would do it =====
     [class, start, duration] in timeline p. Nothing here fades in: SVG marks are drawn by
     letting out a dashoffset, lettering is wiped left→right the way a marker lays ink down.
     The order is the order you would work in — name it, box the three axes, aim the arrows
     that annotate them, then fill the gaps with decoration. The cookie is drawn last, because
     it is the thing the reel opened on, and closing the loop is the last thing you do. */
  var MARKS=[
    ['d-njk',   0.580,0.050],  /* 뉴진스 — the first stroke, landing as the disc reaches its seat */
    ['d-nj',    0.608,0.068],  /* NEWJEANS, big, in red */
    ['d-bang',  0.662,0.022],
    ['d-type',  0.672,0.036],
    ['d-arrow2',0.700,0.028],  /* → NEWJEANS */
    ['d-color', 0.706,0.036],
    ['d-arrow1',0.732,0.028],  /* → COLOR */
    ['d-layout',0.740,0.038],
    ['d-star',  0.762,0.034],
    ['d-star2', 0.774,0.024],
    ['d-heart', 0.778,0.024],
    ['d-smile', 0.784,0.030],
    ['d-star3', 0.786,0.016],
    ['d-spark', 0.792,0.014],
    ['d-heart2',0.796,0.016],
    ['d-note',  0.800,0.024],
    ['d-flow',  0.806,0.028],
    ['d-squig', 0.812,0.020],
    ['d-loop',  0.818,0.018],
    ['d-yeah',  0.822,0.024],
    ['d-cookie',0.826,0.046]
  ];
  var mEl=MARKS.map(function(m){return [E.doodle.querySelector('.'+m[0]),m[1],m[1]+m[2]];});
  var layoutEl=E.doodle.querySelector('.d-layout');

  function frame(p){
    /* pure dark → giant cookie zooms in → bursts (canvas); a few crumbs ride into the blue */
    drawCookie(p);
    /* background snaps dark→blue at the burst */
    var cx=seg(p,0.15,0.20);
    bgDark.style.opacity=1-cx; bgBlue.style.opacity=cx;

    /* the case rises exactly as the giant cookie leaves: its ramp is the mirror of the blurred
       cookie's fade (1 - fa, fa = 1 - seg(p,0.15,0.19)). the bloom is translucent by then, so a
       ramp that finished any earlier would show the printed cover straight through the burst. */
    var open=eOut(seg(p,0.34,0.52)), shut=eOut(seg(p,0.90,1.00));
    var swing=open-shut;                          /* 0 = lid down, 1 = flat open */
    E.kase.style.opacity=seg(p,0.155,0.205);
    E.kase.style.transform='translateX('+(swing*PAN).toFixed(1)+'px) scale('
      +lerp(0.985,1,eOut(seg(p,0.16,0.30))).toFixed(4)+')';
    /* negative: the free edge lifts toward the camera and arcs over the hinge, rather than
       sinking away from it. the same 180deg, the opposite half of the sphere. */
    E.lid.style.transform='rotateY('+(-180*swing).toFixed(2)+'deg)';
    /* light drags across the lid twice: once when the cookie uncovers it, once as it shuts.
       between 0.52 and 0.90 the cover faces away, so resetting the band at 0.86 is unseen. */
    E.cover.style.setProperty('--gloss',
      ((p<0.86?seg(p,0.20,0.33):seg(p,0.90,1.00))*1300).toFixed(0)+'px');

    /* one rake of light across the face — a still disc with a frozen highlight reads as printed */
    E.cd1.style.setProperty('--sweep', lerp(-62,32,eOut(seg(p,0.46,0.72))).toFixed(1)+'deg');
    bug.style.opacity=seg(p,0.20,0.30);
    bug.style.transform='scale('+lerp(0.6,1,eOut(seg(p,0.20,0.32)))+') rotate(-1.5deg)';

    /* burn — the marker goes to work on the bare disc, one mark at a time */
    E.doodle.style.opacity=1;
    for(var i=0;i<mEl.length;i++){ var m=mEl[i];
      m[0].style.setProperty('--w', seg(p,m[1],m[2]).toFixed(3)); }
    /* the highlighter is pulled through LAYOUT after the box around it is closed */
    layoutEl.style.setProperty('--hw', seg(p,0.780,0.808).toFixed(3));

    /* scrubber + hud */
    tcEl.textContent=fmt(p); fill.style.width=(p*100)+'%'; head.style.left=(p*100)+'%';
    if(p<0.055){shotEl.textContent='암전 · black';shotEl.style.color='#9aa0b2';}
    else if(p<0.22){shotEl.textContent='쿠키 · zoom & burst';shotEl.style.color='#e8b06a';}
    else if(p<0.34){shotEl.textContent='파랑 · into blue';shotEl.style.color='#eaf1ff';}
    else if(p<0.56){shotEl.textContent='케이스 · the lid opens';shotEl.style.color='#eaf1ff';}
    else if(p<0.90){shotEl.textContent='룩 · type · color · layout';shotEl.style.color='#eaf1ff';}
    else{shotEl.textContent='닫기 · the lid comes down';shotEl.style.color='#eaf1ff';}
    if(!reduce && lastP<0.15 && p>=0.15){flash.classList.remove('go');void flash.offsetWidth;flash.classList.add('go');}
    lastP=p;
    if(p>0.01) hint.classList.add('hide');
  }

  var ticking=false;
  function onScroll(){ if(!ticking){ticking=true;requestAnimationFrame(function(){frame(clamp(window.scrollY/maxScroll,0,1));ticking=false;});} }
  window.addEventListener('scroll',onScroll,{passive:true});

  /* scrubber click / drag → jump scroll */
  function jump(x){var r=bar.getBoundingClientRect();var f=clamp((x-r.left)/r.width,0,1);window.scrollTo({top:f*maxScroll,behavior:'smooth'});}
  var dragging=false;
  bar.addEventListener('pointerdown',function(e){userInterrupt();dragging=true;bar.setPointerCapture(e.pointerId);jump(e.clientX);});
  bar.addEventListener('pointermove',function(e){if(dragging)jump(e.clientX);});
  bar.addEventListener('pointerup',function(){dragging=false;});

  /* ===== playback — a ▶ that scrolls the timeline; any scroll/touch/drag pauses it ===== */
  var playBtn=$('play');
  var ICON_PLAY='<svg viewBox="0 0 24 24"><path d="M7 5 L19 12 L7 19 Z"/></svg>';
  var ICON_PAUSE='<svg viewBox="0 0 24 24"><path d="M7 5h4v14H7z M13 5h4v14h-4z"/></svg>';
  var PLAY_MS=6000, playing=false, rafId=0, playStart=0, playFromP=0, userTouched=false;
  function setBtn(on){ playBtn.innerHTML=on?ICON_PAUSE:ICON_PLAY; playBtn.setAttribute('aria-label',on?'일시정지':'재생'); playBtn.setAttribute('aria-pressed',on?'true':'false'); }
  function stopPlay(){ if(rafId){cancelAnimationFrame(rafId);rafId=0;} if(playing){playing=false;setBtn(false);} }
  function tickPlay(now){ var p=playFromP+(now-playStart)/PLAY_MS;
    if(p>=1){ window.scrollTo(0,maxScroll); stopPlay(); return; }
    window.scrollTo(0,p*maxScroll); rafId=requestAnimationFrame(tickPlay); }
  function startPlay(){ var cur=clamp(window.scrollY/maxScroll,0,1); if(cur>=0.999)cur=0;
    playFromP=cur; window.scrollTo(0,cur*maxScroll); playStart=performance.now(); playing=true; setBtn(true); rafId=requestAnimationFrame(tickPlay); }
  function togglePlay(){ if(playing)stopPlay(); else startPlay(); }
  function onButton(t){ return playBtn && (t===playBtn || playBtn.contains(t)); }
  function userInterrupt(e){ if(e && onButton(e.target)) return; userTouched=true; stopPlay(); }
  if(playBtn){ setBtn(false); playBtn.addEventListener('click',function(){userTouched=true;togglePlay();}); }
  window.addEventListener('wheel',userInterrupt,{passive:true});
  window.addEventListener('touchstart',userInterrupt,{passive:true});
  window.addEventListener('keydown',function(e){
    if(e.code==='Space'){ if(onButton(e.target))return; e.preventDefault(); userTouched=true; togglePlay(); }
    else if(e.key==='ArrowDown'||e.key==='ArrowUp'||e.key==='PageDown'||e.key==='PageUp'||e.key==='Home'||e.key==='End'){ userInterrupt(); } });

  frame(clamp(window.scrollY/maxScroll,0,1));

  /* autostart once — reveals the intended motion; skipped for reduced-motion or if the user already moved */
  if(!reduce){ setTimeout(function(){ if(!userTouched && window.scrollY<2){ startPlay(); } }, 1100); }
})();
</script>
</body>
</html>
