---
import '../styles/reel.css';
---

<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>COOKIE — 2:13→2:20 (inspired look)</title>
</head>
<body>
<!-- everything lives on a fixed 1200x900 (4:3) "broadcast monitor" scaled to fit the viewport -->
<main role="main" aria-label="NewJeans Cookie MV 2:13에서 2:20까지에서 영감받은 7초 룩 릴">
<h1 class="sr-only">COOKIE — inspired by NewJeans Cookie MV 2:13→2:20</h1>
<div id="frame">
  <div id="box">
    <div class="bg" id="bgDark"></div>
    <div class="bg" id="bgBlue"></div>
    <canvas id="cookie" aria-hidden="true"></canvas>

    <div class="stage">

      <!-- pure dark → giant cookie zooms in → bursts into scattering cookies (canvas) → blue -->

      <!-- ONE OBJECT: a jewel case, shut, lying under the cookie. the burst uncovers it, the
           lid swings open on its left hinge, and the doodled disc has been in the tray the
           whole time. at 2:20 the lid comes back down over it. nothing ever fades in. -->
      <div class="anchor a-case"><div class="case" id="case"><div class="persp">

      <!-- the tray: the right leaf. the disc is clipped to its hub and never moves. -->
      <div class="tray">
        <div class="well" aria-hidden="true"></div>
        <div class="disc cd1" id="cd1">
        <div class="hub" aria-hidden="true"></div>
        <div class="doodle" id="doodle">
          <span class="d-njk">뉴진스</span><span class="d-nj">NEWJEANS</span>
          <span class="d-type">TYPE</span><span class="d-color">COLOR</span><span class="d-layout">LAYOUT</span>
          <span class="d-star"><svg viewBox="0 0 32 32"><path pathLength="1" d="M16 3 L19.7 12 L29 12.7 L21.5 18.8 L24.2 28 L16 22.4 L7.8 28 L10.5 18.8 L3 12.7 L12.3 12 Z"/></svg></span>
          <span class="d-star2"><svg viewBox="0 0 28 28"><path pathLength="1" d="M14.4 3 L13.6 25"/><path pathLength="1" d="M4.6 8.4 L23.4 19.8"/><path pathLength="1" d="M23.6 8.2 L4.8 19.4"/></svg></span>
          <span class="d-smile"><svg viewBox="0 0 40 40"><circle pathLength="1" class="face" cx="20" cy="20" r="15.5"/><circle pathLength="1" class="dot" cx="14.6" cy="17.2" r="2.2"/><circle pathLength="1" class="dot" cx="25.4" cy="17.2" r="2.2"/><path pathLength="1" class="mouth" d="M12.5 24 q7.5 8 15 0"/></svg></span>
          <span class="d-arrow1"><svg viewBox="0 0 46 30"><path pathLength="1" d="M4 22 q13 -19 36 -13"/><path pathLength="1" d="M31 4 l10 4.5 l-7 8"/></svg></span>
          <span class="d-arrow2"><svg viewBox="0 0 46 30"><path pathLength="1" d="M4 22 q13 -19 36 -13"/><path pathLength="1" d="M31 4 l10 4.5 l-7 8"/></svg></span>
          <span class="d-flow"><svg viewBox="0 0 36 36"><ellipse pathLength="1" cx="18" cy="8.5" rx="4.4" ry="7.4"/><ellipse pathLength="1" cx="18" cy="8.5" rx="4.4" ry="7.4" transform="rotate(72 18 18)"/><ellipse pathLength="1" cx="18" cy="8.5" rx="4.4" ry="7.4" transform="rotate(144 18 18)"/><ellipse pathLength="1" cx="18" cy="8.5" rx="4.4" ry="7.4" transform="rotate(216 18 18)"/><ellipse pathLength="1" cx="18" cy="8.5" rx="4.4" ry="7.4" transform="rotate(288 18 18)"/><circle pathLength="1" class="fillc" cx="18" cy="18" r="3.6"/></svg></span>
          <span class="d-heart"><svg viewBox="0 0 28 26"><path pathLength="1" d="M14 23 C14 23 3 15 3 9 C3 5.5 5.5 3 9 3 C11.5 3 13.2 4.4 14 6 C14.8 4.4 16.5 3 19 3 C22.5 3 25 5.5 25 9 C25 15 14 23 14 23 Z"/></svg></span>
          <span class="d-squig"><svg viewBox="0 0 40 18"><path pathLength="1" d="M2 12 q8 -14 16 -2 q8 12 18 -4"/></svg></span>
          <span class="d-spark"><svg viewBox="0 0 20 20"><path pathLength="1" d="M4.2 4.8 L15.4 15.6"/><path pathLength="1" d="M15.8 4.4 L4.6 15.2"/></svg></span>
          <!-- motifs repeated at a very different size: you draw the big one, then dot a small
               one in beside it. this is where the size spread and the density come from -->
          <span class="d-star3"><svg viewBox="0 0 32 32"><path pathLength="1" d="M16 3 L19.7 12 L29 12.7 L21.5 18.8 L24.2 28 L16 22.4 L7.8 28 L10.5 18.8 L3 12.7 L12.3 12 Z"/></svg></span>
          <span class="d-heart2"><svg viewBox="0 0 28 26"><path pathLength="1" d="M14 23 C14 23 3 15 3 9 C3 5.5 5.5 3 9 3 C11.5 3 13.2 4.4 14 6 C14.8 4.4 16.5 3 19 3 C22.5 3 25 5.5 25 9 C25 15 14 23 14 23 Z"/></svg></span>
          <span class="d-note"><svg viewBox="0 0 22 30"><path pathLength="1" d="M13.1 22.6 L14.6 4.4"/><path pathLength="1" d="M14.6 4.4 c4.3 2.1 6.3 4.8 5.4 8.9"/><ellipse pathLength="1" class="head" cx="8.6" cy="23.2" rx="5.3" ry="4.1" transform="rotate(-18 8.6 23.2)"/></svg></span>
          <!-- the loop you scribble to check the marker still has ink in it -->
          <span class="d-loop"><svg viewBox="0 0 26 22"><path pathLength="1" d="M23 10.5 c0 6.2 -5.2 9.4 -10.6 9.2 c-5.8 -0.2 -9.6 -4.2 -9.4 -9.2 c0.2 -4.8 4.1 -7.8 8.1 -7.6 c3.9 0.2 6.7 3.1 6.5 6.2 c-0.2 3 -2.3 4.9 -5 4.7 c-2.2 -0.2 -3.8 -1.9 -3.7 -3.9"/></svg></span>
          <!-- the reel opens on this cookie; here it comes back, drawn in marker. crust wobble
               follows the same law as bigCookie() on the canvas, so both read as one object.
               it is the LAST mark drawn: the seven seconds close on the thing they opened on -->
          <span class="d-cookie"><svg viewBox="0 0 42 34"><path pathLength="1" class="crust" d="M31 17 C31.06 18.1 30.9 19.3 30.54 20.34 C30.19 21.38 29.45 22.3 28.88 23.24 C28.31 24.17 27.81 25.13 27.12 25.97 C26.43 26.8 25.64 27.6 24.77 28.25 C23.89 28.9 22.89 29.42 21.88 29.87 C20.87 30.31 19.78 30.81 18.69 30.93 C17.6 31.04 16.42 30.79 15.36 30.54 C14.29 30.29 13.31 29.81 12.28 29.43 C11.26 29.06 10.16 28.82 9.21 28.28 C8.27 27.74 7.38 26.99 6.64 26.18 C5.9 25.37 5.27 24.4 4.76 23.43 C4.24 22.45 3.75 21.38 3.56 20.31 C3.37 19.24 3.55 18.09 3.61 17 C3.68 15.91 3.79 14.87 3.96 13.79 C4.13 12.7 4.19 11.51 4.63 10.51 C5.08 9.51 5.86 8.61 6.62 7.81 C7.39 7.01 8.29 6.31 9.21 5.72 C10.14 5.13 11.14 4.59 12.17 4.26 C13.2 3.93 14.31 3.89 15.39 3.74 C16.47 3.59 17.56 3.35 18.66 3.36 C19.76 3.37 20.98 3.43 21.99 3.83 C23.01 4.23 23.91 5.04 24.77 5.74 C25.63 6.44 26.43 7.19 27.14 8.02 C27.84 8.85 28.5 9.74 29 10.7 C29.5 11.66 29.81 12.71 30.15 13.76 C30.48 14.81 30.93 15.9 31 17 Z"/><circle pathLength="1" class="chip" cx="12.4" cy="11.6" r="2.3"/><circle pathLength="1" class="chip" cx="21.9" cy="13.2" r="1.6"/><circle pathLength="1" class="chip" cx="16" cy="17.6" r="2.5"/><circle pathLength="1" class="chip" cx="23" cy="21.4" r="1.9"/><circle pathLength="1" class="chip" cx="11.3" cy="21.9" r="1.7"/><circle pathLength="1" class="chip" cx="17.6" cy="25.3" r="1.2"/><circle pathLength="1" class="chip" cx="9.8" cy="16.4" r="1.1"/><circle pathLength="1" class="crumb" cx="35.6" cy="25.7" r="1.7"/><circle pathLength="1" class="crumb" cx="39.2" cy="21.1" r="1.05"/></svg></span>
          <span class="d-bang">!!</span>
          <span class="d-yeah">Y2K</span>
        </div>
      </div>
      </div>

      <!-- the lid. one booklet, two covers: shut you read its front through the clear
           plastic; opened flat it lies to the left of the hinge and you read its back.
           the lid is the only 3D node, so opacity and the pan live on .case above it:
           opacity on a preserve-3d node collapses it to flat and kills backface-visibility. -->
      <div class="lid" id="lid">
        <!-- the four walls. without them the lid is a plane, and a plane has no edge to show
             halfway through the swing: it goes to a hairline and the case reads as paper. -->
        <div class="rim r-top" aria-hidden="true"></div>
        <div class="rim r-bot" aria-hidden="true"></div>
        <div class="rim r-free" aria-hidden="true"></div>
        <div class="rim r-hinge" aria-hidden="true"></div>

        <div class="face cover" id="cover">
          <div class="spine"><span>COOKIE · 뉴진스 · REEL 02 · CJ-0220</span></div>
          <div class="bk">
            <!-- the print's working layer: what the shop leaves on a sheet, not decoration.
                 the dashed circle is the disc on the OTHER side of the hinge, specified where
                 it will shadow this cover (RCX,RCY,RR mirrored into bk coords: 285,233,142),
                 so the crumbs land ON a drawing of the thing they trace. registration marks,
                 a dimension callout and a ruler say Y2K the way the era actually said it:
                 as manufacture, not as ornament. -->
            <svg class="jk-spec" viewBox="0 0 549 550" aria-hidden="true">
              <g class="rg">
                <g transform="translate(16,16)"><circle r="5"/><path d="M-9 0H9M0 -9V9"/></g>
                <g transform="translate(533,16)"><circle r="5"/><path d="M-9 0H9M0 -9V9"/></g>
                <g transform="translate(16,534)"><circle r="5"/><path d="M-9 0H9M0 -9V9"/></g>
                <g transform="translate(533,534)"><circle r="5"/><path d="M-9 0H9M0 -9V9"/></g>
              </g>
              <circle class="c1" cx="285" cy="233" r="142"/>
              <circle class="c2" cx="285" cy="233" r="24"/>
              <path class="cx" d="M277 233H293M285 225V241"/>
              <path class="ld" d="M397 146L452 108H470"/>
              <text class="tx" x="474" y="111">Ø 120</text>
              <path class="rl" d="M536 120h6M538 144h4M538 168h4M538 192h4M536 216h6M538 240h4M538 264h4M538 288h4M536 312h6M538 336h4M538 360h4M538 384h4M536 408h6"/>
            </svg>
            <div class="jk-top"><span class="jk-kr">뉴진스</span><span class="jk-ser">LOOK BOOK 02</span></div>
            <!-- nothing is printed here. the crumbs land in this space and stay:
                 on the spec drawing of the disc that is about to shadow it. -->
            <div class="jk-void" aria-hidden="true"></div>
            <h3 class="jk-title">COOKIE</h3>
            <div class="jk-foot"><span>2:13 → 2:20 · INSPIRED LOOK</span><span class="endtag">2:20:00 — next look ↓</span></div>
          </div>
          <div class="plastic" aria-hidden="true"></div>
          <!-- on the WRAP, not the print: the era's hype sticker lived on the shrink film.
               it half-covers the series label beneath it, which is exactly what makes it
               read as an object and not part of the layout. it rides the lid like the
               crumbs do, and sits under them in z: it was there before they fell. -->
          <div class="hype" aria-hidden="true">
            <span class="h-k">REEL 02</span>
            <b>LOOK 02</b>
            <span class="h-s">2:13 → 2:20</span>
          </div>
          <!-- above the plastic: they fell on the outside of the lid, not inside it. JS bakes
               one little canvas per crumb at the coordinates the physics left it. -->
          <div class="crumbs" id="crumbs" aria-hidden="true"></div>
        </div>

        <div class="face inside">
          <div class="spine"><span>TYPE · COLOR · LAYOUT</span></div>
          <div class="bk ib">
            <div class="ib-head"><span class="ib-kick">Look 02 · 2:16</span><span class="ib-ser">B/W 2:20:00</span></div>
            <h2>그리고,<br>파랑.<svg class="ib-ul" viewBox="0 0 170 12" aria-hidden="true"><path pathLength="1" d="M3 8 q24 -8 50 -1 q26 7 54 -2 q28 -8 60 1"/></svg></h2>
            <p class="lede">Cookie MV 2:13–2:20에서 가져온 컷. 전기 블루 필드, 그 위에 뜨는 방송용 크롬 타이포.<br><span style="opacity:.62">A cut borrowed from Cookie MV 2:13–2:20. Electric blue field, broadcast chrome type on top.</span></p>
            <ol class="tl">
              <li><b>1</b><span>type</span></li>
              <li><b>2</b><span>color</span></li>
              <li class="on"><b>3</b><span>layout</span></li>
            </ol>
            <!-- the small print a real back cover carries. it is also the honest place to say
                 what this is: a look study, not a release. -->
            <p class="ib-fine">Inspired by the Cookie MV, 2:13–2:20.<br>A look study. Not affiliated with ADOR or NewJeans.<br>Authored on a 1200×900 stage · scroll-scrubbed</p>
            <div class="ib-foot">
              <div class="barcode" aria-hidden="true"></div>
              <div class="ib-cat">CJ-0220 · REEL 02</div>
            </div>
          </div>
        </div>

      </div>

      </div></div></div>

    </div>

    <div class="bug" id="bug" aria-hidden="true">
      <div class="lz"><span class="n1">y2k</span><span class="n2">design.md</span></div>
    </div>

    <div class="grain"></div>
    <div class="vig"></div>
    <div class="scan" aria-hidden="true"></div>

    <div class="topbar">
      <div class="reel"><span class="dot"></span> COOKIE · 뉴진스 &nbsp;— &nbsp;REEL 02</div>
      <div class="shot" id="shot">암전 · black</div>
    </div>

    <div class="hint" id="hint" aria-hidden="true">아래로 스크롤 · scroll to play <span class="arw">↓</span></div>

    <div class="scrubber" role="region" aria-label="타임코드 스크러버 · 재생, 클릭이나 드래그로 이동">
      <button class="playbtn" id="play" type="button" aria-label="재생" aria-pressed="false"><svg viewBox="0 0 24 24"><path d="M7 5 L19 12 L7 19 Z"/></svg></button>
      <div class="tc"><span id="tc">2:13:00</span><small>2:13 → 2:20</small></div>
      <!-- it looks like a slider and it drags like a slider, so it says it is one. valuenow is
           a percentage of the reel; valuetext is the timecode, which is what a reader wants. -->
      <div class="track-bar" id="bar" tabindex="0" role="slider"
           aria-label="타임코드 · timecode" aria-orientation="horizontal"
           aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" aria-valuetext="2:13:00">
        <div class="rail"></div><div class="fill" id="fill"></div>
        <div class="cut" style="left:16%"></div><div class="marks" id="marks"></div><div class="head" id="head"></div>
      </div>
    </div>

    <div class="flash" id="flash"></div>
  </div>
</div>
</main>

<div class="track" id="track" aria-hidden="true"></div>

<script is:inline>
(function(){
  var $=function(id){return document.getElementById(id);};
  var bgDark=$('bgDark'),bgBlue=$('bgBlue'),bug=$('bug'),flash=$('flash'),
      tcEl=$('tc'),fill=$('fill'),head=$('head'),shotEl=$('shot'),hint=$('hint'),
      bar=$('bar'),marks=$('marks');
  var E={cd1:$('cd1'),doodle:$('doodle'),kase:$('case'),lid:$('lid'),cover:$('cover')};
  var reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* the whole reel is authored on a fixed 1200x900 (4:3) stage and scaled to fit */
  var BW=1200, BH=900;

  /* THE PANEL IS DECLARED ONCE, IN CSS, AND EVERYTHING HERE IS DERIVED FROM IT.
     It used to be written out four times: .case in the stylesheet, PAN, the crumbs' seat, and
     the gloss travel. Three of those were in this file, and none of them knew about the first.
     Editing the stylesheet moved the case and left the crumbs behind, silently, with a clean
     build. Read it instead. */
  var ROOT=getComputedStyle(document.documentElement);
  function cssPx(n){ return parseFloat(ROOT.getPropertyValue(n)); }
  var PW=cssPx('--panel-w'), PH=cssPx('--panel-h');
  var PAN=PW/2;          /* shut, the case is centred on the stage; open, the spread is */
  var SPREAD=PW*2;       /* two leaves, and the distance the gloss band has to cross */
  var PANEL_X=(BW-PW)/2, PANEL_Y=(BH-PH)/2;   /* the shut case's top-left, in stage coords */
  function fitStage(){ var f=Math.min(innerWidth/BW, innerHeight/BH);
    var d=document.documentElement.style; d.setProperty('--fit', f);
    d.setProperty('--scan', f>=0.62?0.16:0);   /* kill scanlines when scaled small (moiré) */
    return f; }

  var mh='';for(var s=0;s<=7;s++){mh+='<b style="left:'+(s/7*100)+'%">2:'+(13+s)+'</b>';}marks.innerHTML=mh;

  /* the one deck the whole reel is dealt from: a seed in, a stream out. it used to be written
     out once per population, three times, and the three copies could have drifted apart with
     nothing to notice. the only symptom would have been a different cookie. */
  function lcg(seed){ var r=seed;
    return function(){ r=(r*9301+49297)%233280; return r/233280; }; }

  function clamp(v,a,b){return v<a?a:v>b?b:v;}
  function seg(p,a,b){return clamp((p-a)/(b-a),0,1);}
  function lerp(a,b,t){return a+(b-a)*t;}
  function eOut(t){return 1-Math.pow(1-t,3);}
  function pad(n){return(n<10?'0':'')+n;}
  function fmt(p){var f=133*24+Math.round(p*168),sec=Math.floor(f/24),ff=f%24;return Math.floor(sec/60)+':'+pad(sec%60)+':'+pad(ff);}

  /* ===== cookie zoom + burst engine (canvas, drawn in 1200x900 stage coords) ===== */
  var cv=$('cookie'), ctx=cv.getContext('2d'), DPR=Math.min(2,window.devicePixelRatio||1);
  function sizeCookie(){ var f=fitStage();
    cv.width=Math.round(BW*f*DPR); cv.height=Math.round(BH*f*DPR);
    cv.style.width=BW+'px'; cv.style.height=BH+'px'; ctx.setTransform(f*DPR,0,0,f*DPR,0,0); }
  sizeCookie();   /* the resize listener is installed below, once frame() exists to repaint */
  /* milk-glass pastels, not primaries. the reel's world is black, dough and timecode orange;
     a full-saturation candy set read as a logo dropped into it. these keep each hue's name
     but pull it toward milk, which is where the Y2K frame and the MV's props live. */
  var MM=['#a3c47e','#88b4e2','#e28275','#eed06a','#f0a984','#ab8fd4'];
  var TOP=[ {x:-0.48,y:-0.42,r:0.17,c:'#a3c47e',mm:1},{x:0.34,y:-0.5,r:0.18,c:'#5a2d1c',mm:0},
    {x:-0.56,y:0.48,r:0.16,c:'#88b4e2',mm:1},{x:0.6,y:0.42,r:0.15,c:'#eed06a',mm:1},
    {x:0.42,y:-0.05,r:0.10,c:'#e28275',mm:1},{x:0.66,y:-0.34,r:0.07,c:'#ab8fd4',mm:1},
    {x:0.04,y:0.12,r:0.11,c:'#4a2c17',mm:0},{x:-0.18,y:-0.08,r:0.08,c:'#4a2c17',mm:0},
    {x:-0.32,y:0.2,r:0.09,c:'#4a2c17',mm:0},{x:0.16,y:0.5,r:0.09,c:'#4a2c17',mm:0},{x:-0.04,y:-0.5,r:0.08,c:'#4a2c17',mm:0} ];

  /* the crust wobble, one law, shared by the canvas cookie, the disc doodle and the jacket art */
  function crustPath(g,cx,cy,R,N){ g.beginPath();
    for(var i=0;i<=N;i++){ var a=i/N*6.283, rad=R*(0.96+0.04*Math.sin(a*5+1.2)+0.02*Math.sin(a*9));
      var x=cx+Math.cos(a)*rad, y=cy+Math.sin(a)*rad; i?g.lineTo(x,y):g.moveTo(x,y); }
    g.closePath(); }

  /* a chocolate chunk is a broken solid: a body, a facet where the break caught the light,
     and one small specular on the facet's edge. a flat polygon with a soft blob on it is
     the plastic look — the facet is what makes it read as broken chocolate. */
  function chunk(g,x,y,r,rot,jag){ var i,pts=[];
    for(i=0;i<jag.length;i++){ var a=rot+i/jag.length*6.283;
      pts.push([x+Math.cos(a)*r*jag[i], y+Math.sin(a)*r*jag[i]]); }
    function poly(sh,dx,dy){ g.beginPath();
      for(i=0;i<pts.length;i++){ var px=x+(pts[i][0]-x)*sh+dx, py=y+(pts[i][1]-y)*sh+dy;
        i?g.lineTo(px,py):g.moveTo(px,py); } g.closePath(); }
    g.save();
    g.shadowColor='rgba(58,28,7,.5)'; g.shadowBlur=r*0.3; g.shadowOffsetY=r*0.1;
    poly(1,0,0);
    var cg=g.createLinearGradient(x-r*0.8,y-r*0.8,x+r*0.7,y+r*0.9);
    cg.addColorStop(0,'#6a4527');cg.addColorStop(0.42,'#3a2213');cg.addColorStop(1,'#1b0f08');
    g.fillStyle=cg; g.fill(); g.shadowColor='transparent';
    /* each break catches the light its own way: the facet and its specular vary per chunk,
       derived from the jag it already owns (no extra randomness to thread through). the
       offsets stay negative so the key light never leaves the top-left. an identical white
       ellipse on three chunks in one macro frame read as a copy-paste, because it was one. */
    var u=(jag[0]-0.78)/0.34, v=(jag[1]-0.78)/0.34, w=(jag[2]-0.78)/0.34;
    poly(0.6,-r*(0.11+0.12*u),-r*(0.13+0.12*v));
    g.fillStyle='rgba(150,102,60,.28)'; g.fill();
    g.beginPath(); g.ellipse(x-r*(0.24+0.18*v),y-r*(0.26+0.2*u),r*(0.13+0.11*w),r*(0.06+0.07*u),-0.4-0.6*w,0,6.283);
    g.fillStyle='rgba(255,238,212,'+(0.16+0.16*v).toFixed(2)+')'; g.fill();
    g.restore(); }

  /* a candy shell is matte, not chrome. a broad soft light off the top-left, a thin dark rim
     where the shell turns away, and a specular small enough to stay a shell and not a marble. */
  function candy(g,x,y,r,c,tilt){ var ry=r*0.95; g.save();
    g.shadowColor='rgba(58,28,7,.45)'; g.shadowBlur=r*0.42; g.shadowOffsetY=r*0.15;
    g.beginPath(); g.ellipse(x,y,r,ry,tilt,0,6.283); g.fillStyle=c; g.fill();
    g.shadowColor='transparent';
    /* the light stays flat across the middle and only falls off in the last fifth of the
       radius. a gradient that brightens from the centre outward is what makes a marble. */
