         down-right. one drawImage lays down the shadow and the piece together. */
      g.shadowColor='rgba(34,24,10,.42)'; g.shadowOffsetX=2; g.shadowOffsetY=3; g.shadowBlur=2.6;
      g.drawImage(t,0,0,S,S);
